# ── Slideshow Studio — Environment Configuration ──────────────────────────────

# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=slideshowstudio-dev-key-change-this-later

# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL=sqlite:///slideshow_studio.db
# DATABASE_URL=postgresql://user:password@localhost/slideshow_studio

# ── Storage ───────────────────────────────────────────────────────────────────
# pCloud drive (all user files — photos, audio, processed frames, output MP4s)
STORAGE_ROOT=P:\slideshow

# Local SSD temp dir (ffmpeg working files during render — auto-deleted after)
TEMP_ROOT=D:\Temp\slideshow_render

# ── Render engine ─────────────────────────────────────────────────────────────
SLIDESHOW_MAKER_PATH=P:\slideshow\Slideshow_MP4_Generator_v2.5\slideshow_maker.py
FFMPEG_PATH=ffmpeg

# ── Admin account ─────────────────────────────────────────────────────────────
ADMIN_EMAIL=gurmeet.singh@cadglobal.ca

# ── App URL ───────────────────────────────────────────────────────────────────
# Dev:
APP_URL=http://localhost:5000
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
# Production (Cloudflare Tunnel):
# APP_URL=https://app.calgarydhamaka.com
# GOOGLE_REDIRECT_URI=https://app.calgarydhamaka.com/auth/google/callback

# ── SMS / OTP (Twilio) ────────────────────────────────────────────────────────
# Leave blank in dev — OTP prints to console instead of sending SMS
TWILIO_ACCOUNT_SID=   # leave blank in dev — OTP prints to console
#TWILIO_ACCOUNT_SID=ACxxxxxxxx
#TWILIO_AUTH_TOKEN=your-token
#TWILIO_FROM_NUMBER=+12045551234

# ── Redis (Celery job queue for background renders) ───────────────────────────
# Optional in dev — renders run synchronously if Redis not available
REDIS_URL=redis://localhost:6379/0

# ── Email (optional) ──────────────────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
